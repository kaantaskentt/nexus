# ── Tier 1 — blocking ────────────────────────────────────────────
ANTHROPIC_API_KEY=            # reasoning: compiler, interviewer, planner
OPENAI_API_KEY=               # embeddings only (text-embedding-3-small)
VAPI_API_KEY=                 # server key — assistant mgmt + calls
VAPI_PUBLIC_KEY=              # web SDK (browser voice calls)
FIRECRAWL_API_KEY=            # Stage 1 website/company scrape
SENDGRID_API_KEY=             # interview invites (or swap for RESEND_API_KEY)

# ── Tier 2 — full pipeline ───────────────────────────────────────
APIFY_TOKEN=                  # Stage 1 LinkedIn people scrape (names+roles only)
FIREFLIES_API_KEY=            # CEO-call transcript auto-ingest

# ── Set by me via Supabase MCP once you confirm the org ──────────
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── Deploy (CLI login preferred over tokens) ─────────────────────
# vercel login / railway login — run once in my terminal

# ── App config ───────────────────────────────────────────────────
APP_BASE_URL=                 # public URL (VAPI webhook + invite links)
EMAIL_FROM=                   # verified sender, e.g. interviews@<domain>
DEFAULT_ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
